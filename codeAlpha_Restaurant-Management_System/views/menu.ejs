<%- include('partials/header') %>

<div class="bg-royal-dark text-white py-16 text-center relative overflow-hidden">
    <h1 class="font-serif text-5xl font-bold mb-4 relative z-10">Our Royal Menu</h1>
    <p class="text-stone-300 text-lg max-w-2xl mx-auto font-light relative z-10">Explore our carefully curated selection of pure vegetarian delicacies.</p>
</div>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    
    <% if (Object.keys(groupedMenu).length === 0) { %>
        <div class="text-center py-20">
            <h3 class="text-2xl text-stone-600 font-medium">Menu is currently being updated.</h3>
        </div>
    <% } else { %>
        
        <!-- EXPLICIT CATEGORY ORDER APPLIED HERE -->
        <% 
        const categoryOrder = ['Fast Food & Snacks', 'Indian Thali', 'Beverages', 'Desserts', 'Ice Creams'];
        categoryOrder.forEach(category => { 
            if (groupedMenu[category] && groupedMenu[category].length > 0) {
        %>
            <section class="mb-16" id="<%= category.replace(/\s+/g, '') %>">
                
                <div class="flex items-center gap-4 mb-8">
                    <h2 class="font-serif text-3xl font-bold text-royal-dark"><%= category %></h2>
                    <div class="h-px bg-stone-300 flex-grow"></div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
                    <% groupedMenu[category].forEach(item => { %>
                        
                        <div class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all border border-stone-100 flex flex-col group">
                            <div class="relative aspect-square overflow-hidden bg-white p-2 border-b border-stone-100">
                                <img src="<%= item.imagePath %>" alt="<%= item.name %>" class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-500">
                                <% if (item.isVeg) { %>
                                    <div class="absolute top-3 right-3 bg-white p-1 rounded border border-green-600 shadow-sm" title="Pure Veg">
                                        <div class="w-3 h-3 bg-green-600 rounded-full"></div>
                                    </div>
                                <% } %>
                            </div>
                            
                            <div class="p-5 flex-1 flex flex-col">
                                <div class="flex justify-between items-start mb-2">
                                    <h3 class="font-bold text-lg text-gray-900 leading-tight"><%= item.name %></h3>
                                </div>
                                <span class="font-bold text-royal-red text-xl mb-3">₹<%= item.price %></span>
                                
                                <% if (item.description) { %>
                                    <p class="text-sm text-stone-500 line-clamp-2 mb-4"><%= item.description %></p>
                                <% } %>
                                
                                <button 
                                    type="button"
                                    data-id="<%= item._id %>"
                                    data-name="<%= item.name %>"
                                    data-price="<%= item.price %>"
                                    onclick="addToCart(this)"
                                    class="mt-auto w-full bg-stone-100 hover:bg-royal-red hover:text-white text-royal-dark font-bold py-3 rounded-lg transition-colors border border-stone-200 hover:border-royal-red shadow-sm">
                                    Add to Cart
                                </button>
                            </div>
                        </div>

                    <% }) %>
                </div>
            </section>
        <% 
            } 
        }); 
        %>
    <% } %>
</main>

<button onclick="toggleCart()" id="floating-cart-btn" class="fixed bottom-8 right-8 bg-royal-red hover:bg-red-700 text-white p-4 rounded-full shadow-2xl flex items-center gap-3 transition-transform z-40 group">
    <svg class="w-6 h-6 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
    <span class="font-bold text-lg pr-2">Cart (<span id="fab-count">0</span>)</span>
</button>

<div id="cart-overlay" onclick="toggleCart()" class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300"></div>

<div id="cart-drawer" class="fixed top-0 right-0 h-full w-full sm:w-[450px] bg-white z-50 transform translate-x-full transition-transform duration-300 shadow-2xl flex flex-col">
    
    <div class="bg-royal-dark text-white p-6 flex justify-between items-center shadow-md z-10">
        <h2 class="font-serif font-bold text-2xl tracking-wide flex items-center gap-3">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
            Your Order
        </h2>
        <button onclick="toggleCart()" class="text-gray-400 hover:text-white transition-colors bg-gray-800 p-2 rounded-full">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
    </div>
    
    <div class="flex-1 overflow-y-auto p-6 bg-stone-50" id="cart-items">
        <div class="h-full flex flex-col items-center justify-center text-stone-400" id="empty-cart-msg">
            <svg class="w-16 h-16 mb-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            <p class="text-lg">Your cart is hungry.</p>
        </div>
    </div>

    <div class="p-6 border-t border-stone-200 bg-white shadow-[0_-10px_15px_-3px_rgba(0,0,0,0.05)]">
        <div class="flex justify-between items-end mb-6">
            <span class="text-stone-500 font-medium">Grand Total</span>
            <span class="font-bold text-3xl text-royal-red" id="cart-total">₹0</span>
        </div>

        <form action="/order" method="POST" id="checkout-form" class="space-y-4">
            <input type="hidden" name="cartData" id="cartDataInput">
            
            <div class="grid grid-cols-2 gap-4">
                <div class="col-span-2">
                    <input type="text" name="customerName" required placeholder="Full Name" class="w-full px-4 py-3 border border-stone-300 rounded-lg focus:ring-2 focus:ring-royal-red outline-none bg-stone-50 transition-colors">
                </div>
                <div class="col-span-2">
                    <input type="number" name="tableNumber" placeholder="Table Number (If Dine-in)" class="w-full px-4 py-3 border border-stone-300 rounded-lg focus:ring-2 focus:ring-royal-red outline-none bg-stone-50 transition-colors">
                </div>
                <div class="col-span-2">
                    <textarea name="specialInstructions" rows="2" placeholder="Special Instructions (e.g., Less spicy)..." class="w-full px-4 py-3 border border-stone-300 rounded-lg focus:ring-2 focus:ring-royal-red outline-none bg-stone-50 transition-colors"></textarea>
                </div>
            </div>

            <button type="submit" id="checkout-btn" disabled class="w-full bg-stone-300 text-stone-500 font-bold py-4 rounded-lg transition-all cursor-not-allowed mt-4">
                Confirm & Place Order
            </button>
        </form>
    </div>
</div>

<script>
    let cart = [];
    
    const drawer = document.getElementById('cart-drawer');
    const overlay = document.getElementById('cart-overlay');
    let isCartOpen = false;

    function toggleCart() {
        isCartOpen = !isCartOpen;
        if (isCartOpen) {
            drawer.classList.remove('translate-x-full');
            overlay.classList.remove('hidden');
            setTimeout(() => overlay.classList.remove('opacity-0'), 10); 
        } else {
            drawer.classList.add('translate-x-full');
            overlay.classList.add('opacity-0');
            setTimeout(() => overlay.classList.add('hidden'), 300); 
        }
    }

    function addToCart(buttonElement) {
        const id = buttonElement.getAttribute('data-id');
        const name = buttonElement.getAttribute('data-name');
        const price = parseFloat(buttonElement.getAttribute('data-price'));

        const existingItem = cart.find(item => item.id === id);
        
        if (existingItem) {
            existingItem.quantity += 1;
        } else {
            cart.push({ id, name, price, quantity: 1 });
        }
        
        updateCartUI();

        const fab = document.getElementById('floating-cart-btn');
        fab.classList.add('scale-110');
        setTimeout(() => fab.classList.remove('scale-110'), 200);
    }

    function removeFromCart(id) {
        cart = cart.filter(item => item.id !== id);
        updateCartUI();
    }

    function updateCartUI() {
        const cartItemsContainer = document.getElementById('cart-items');
        const emptyMsg = document.getElementById('empty-cart-msg');
        const fabCount = document.getElementById('fab-count');
        const cartTotal = document.getElementById('cart-total');
        const checkoutBtn = document.getElementById('checkout-btn');
        const cartDataInput = document.getElementById('cartDataInput');

        let total = 0;
        let count = 0;
        
        cartItemsContainer.innerHTML = ''; 
        cartItemsContainer.appendChild(emptyMsg);

        if (cart.length === 0) {
            emptyMsg.style.display = 'flex';
            checkoutBtn.disabled = true;
            checkoutBtn.className = "w-full bg-stone-300 text-stone-500 font-bold py-4 rounded-lg transition-all cursor-not-allowed mt-4";
        } else {
            emptyMsg.style.display = 'none';
            checkoutBtn.disabled = false;
            checkoutBtn.className = "w-full bg-royal-red hover:bg-red-700 text-white shadow-lg font-bold py-4 rounded-lg transition-all transform hover:-translate-y-1 mt-4";

            cart.forEach(item => {
                const itemTotal = item.price * item.quantity;
                total += itemTotal;
                count += item.quantity;

                const itemDiv = document.createElement('div');
                itemDiv.className = "flex justify-between items-center mb-4 bg-white p-4 rounded-xl shadow-sm border border-stone-100";
                itemDiv.innerHTML = `
                    <div class="flex-1">
                        <h4 class="text-base font-bold text-gray-900">${item.name}</h4>
                        <div class="text-sm text-gray-500 mt-1">₹${item.price} <span class="mx-1">x</span> <span class="bg-gray-100 text-gray-800 px-2 py-0.5 rounded font-bold">${item.quantity}</span></div>
                    </div>
                    <div class="text-right">
                        <div class="font-bold text-gray-800 mb-2">₹${itemTotal}</div>
                        <button type="button" onclick="removeFromCart('${item.id}')" class="text-red-500 hover:text-red-700 text-xs font-medium uppercase tracking-wider bg-red-50 px-2 py-1 rounded transition-colors">
                            Remove
                        </button>
                    </div>
                `;
                cartItemsContainer.appendChild(itemDiv);
            });
        }

        fabCount.innerText = count;
        cartTotal.innerText = `₹${total}`;
        
        cartDataInput.value = JSON.stringify(cart);
    }
</script>

<%- include('partials/footer') %>