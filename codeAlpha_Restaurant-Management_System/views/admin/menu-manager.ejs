<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Title Image (Favicon) -->
    <link rel="icon" type="image/png" href="/images/mainlogoremovebg.png">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 flex h-screen relative z-0">

    <!-- Transparent Background Watermark -->
    <div class="fixed inset-0 z-[-1] flex items-center justify-center pointer-events-none overflow-hidden ml-0 md:ml-64">
        <img src="/images/mainlogoremovebg.png" alt="Watermark" class="w-[80%] md:w-[50%] object-contain opacity-5 grayscale">
    </div>

    <!-- Admin Sidebar -->
    <aside class="w-64 bg-slate-900 text-white flex flex-col hidden md:flex z-10">
        <div class="p-6">
            <h2 class="text-2xl font-bold font-serif text-amber-400">The Royals</h2>
            <p class="text-xs text-slate-400 uppercase tracking-wider mt-1">Management Portal</p>
        </div>
        <nav class="flex-1 px-4 space-y-2 mt-4">
            <a href="/admin" class="block px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors">Reservations</a>
            <a href="/admin/menu" class="block px-4 py-3 bg-slate-800 rounded-lg text-white font-medium">Menu Manager</a>
            <a href="/" target="_blank" class="block px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors mt-8">View Live Site ↗</a>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto p-8 z-10">
        <header class="mb-8 flex justify-between items-center">
            <h1 class="text-3xl font-bold text-gray-800">Manage Menu Items</h1>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Add New Item Form -->
            <div class="bg-white/90 backdrop-blur-sm p-6 rounded-xl shadow-sm border border-gray-200 h-fit">
                <h2 class="text-xl font-bold text-gray-800 mb-4">Add New Item</h2>
                <form action="/admin/menu/add" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Item Name</label>
                        <input type="text" name="name" required class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-slate-900 outline-none bg-white/50">
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
                        <select name="category" required class="w-full border border-gray-300 rounded-lg px-3 py-2 bg-white/50 outline-none">
                            <option value="Fast Food & Snacks">Fast Food & Snacks</option>
                            <option value="Indian Thali">Indian Thali</option>
                            <option value="Beverages">Beverages</option>
                            <option value="Desserts">Desserts</option>
                            <option value="Ice Creams">Ice Creams</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Price (₹)</label>
                        <input type="number" name="price" required class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-slate-900 outline-none bg-white/50">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Image Path</label>
                        <input type="text" name="imagePath" required class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-slate-900 outline-none bg-white/50" placeholder="/images/item.jpg">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Description (Optional)</label>
                        <textarea name="description" rows="2" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-slate-900 outline-none bg-white/50"></textarea>
                    </div>

                    <div class="flex items-center">
                        <input type="checkbox" name="isVeg" id="isVeg" checked class="h-4 w-4 text-green-600 rounded border-gray-300">
                        <label for="isVeg" class="ml-2 block text-sm text-gray-700">Pure Veg</label>
                    </div>

                    <button type="submit" class="w-full bg-slate-900 hover:bg-slate-800 text-white font-medium py-2 rounded-lg transition-colors mt-2">
                        Save Menu Item
                    </button>
                </form>
            </div>

            <!-- Current Menu Items List -->
            <div class="lg:col-span-2 bg-white/90 backdrop-blur-sm rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50/90">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Item</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Price</th>
                            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        <% if (menuItems.length === 0) { %>
                            <tr>
                                <td colspan="4" class="px-6 py-8 text-center text-gray-500">No items in the database. Add one to the left!</td>
                            </tr>
                        <% } else { %>
                            <% menuItems.forEach(item => { %>
                                <tr class="hover:bg-gray-50">
                                    <td class="px-6 py-4 whitespace-nowrap flex items-center gap-3">
                                        <img src="<%= item.imagePath %>" class="w-10 h-10 rounded object-cover border border-gray-200 bg-white">
                                        <div>
                                            <div class="font-medium text-gray-900"><%= item.name %></div>
                                            <div class="text-xs text-gray-500"><%= item.isVeg ? '🟩 Veg' : '🟥 Non-Veg' %></div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                        <span class="bg-gray-100 px-2 py-1 rounded text-gray-700"><%= item.category %></span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-900">
                                        ₹<%= item.price %>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                        <form action="/admin/menu/delete/<%= item._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this item?');">
                                            <button type="submit" class="text-red-600 hover:text-red-900 bg-red-50 hover:bg-red-100 px-3 py-1 rounded transition-colors">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</body>
</html>