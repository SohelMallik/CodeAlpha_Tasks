<%- include('partials/header') %>

<section class="relative h-[80vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
        <img src="/images/home_img1.jpg" alt="Restaurant Interior" class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-royal-dark/60"></div>
    </div>
    
    <div class="relative z-10 text-center px-4">
        <h2 class="font-serif text-5xl md:text-7xl text-white font-bold mb-6 drop-shadow-lg">Experience Royalty</h2>
        <p class="text-xl md:text-2xl text-stone-200 mb-10 max-w-2xl mx-auto font-light">A pure vegetarian culinary journey through authentic Indian flavors and exquisite desserts.</p>
        <a href="/menu" class="bg-royal-red hover:bg-royal-redHover text-white px-8 py-4 rounded-full font-semibold text-lg transition-all shadow-[0_0_20px_rgba(220,38,38,0.4)] hover:scale-105 inline-block">Explore Our Menu</a>
    </div>
</section>

<section id="about" class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="font-serif text-4xl text-royal-dark font-bold mb-8">Our Story</h2>
        <div class="text-stone-600 space-y-6 leading-relaxed text-lg">
            <p>
                Welcome to The Royals, where the essence of royalty is blended with a delightful culinary journey. Upholding the slogan, "Be royal, live royal," our restaurant is designed to provide an extraordinary dining experience. As a pure vegetarian establishment, we specialize in serving a wide variety of Indian fast foods, snacks, Indian thalis, refreshing juices, exquisite mocktails, indulgent desserts, and creamy ice creams.
            </p>
            <p>
                Every detail, from the ambiance to the flavors, has been curated to give our guests a majestic and unforgettable experience. Whether you're here to savor an authentic Indian thali or enjoy refreshing mocktails, our offerings promise to leave you with a taste of royalty.
            </p>
        </div>
    </div>
</section>

<section id="booking" class="py-20 bg-royal-light">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-amber-100">
            <div class="bg-royal-dark py-6 px-8 text-center">
                <h2 class="font-serif text-3xl text-white font-bold">Reserve Your Table</h2>
                <p class="text-stone-300 mt-2 text-sm">Book online and skip the waiting line.</p>
            </div>
            
            <form action="/book" method="POST" class="p-8 space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-stone-700 mb-1">Full Name</label>
                        <input type="text" name="name" required class="w-full px-4 py-3 rounded-lg border border-stone-300 focus:ring-2 focus:ring-royal-red focus:border-royal-red outline-none transition-shadow bg-stone-50">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-stone-700 mb-1">Email Address</label>
                        <input type="email" name="email" required class="w-full px-4 py-3 rounded-lg border border-stone-300 focus:ring-2 focus:ring-royal-red focus:border-royal-red outline-none transition-shadow bg-stone-50">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-stone-700 mb-1">Phone Number</label>
                        <input type="tel" name="phone" required class="w-full px-4 py-3 rounded-lg border border-stone-300 focus:ring-2 focus:ring-royal-red focus:border-royal-red outline-none transition-shadow bg-stone-50">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-stone-700 mb-1">Number of Guests</label>
                        <input type="number" name="guests" min="1" max="50" required class="w-full px-4 py-3 rounded-lg border border-stone-300 focus:ring-2 focus:ring-royal-red focus:border-royal-red outline-none transition-shadow bg-stone-50">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-stone-700 mb-1">Date</label>
                        <input type="date" name="date" required class="w-full px-4 py-3 rounded-lg border border-stone-300 focus:ring-2 focus:ring-royal-red focus:border-royal-red outline-none transition-shadow bg-stone-50">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-stone-700 mb-1">Time</label>
                        <input type="time" name="time" required class="w-full px-4 py-3 rounded-lg border border-stone-300 focus:ring-2 focus:ring-royal-red focus:border-royal-red outline-none transition-shadow bg-stone-50">
                    </div>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-stone-700 mb-1">Special Requests (Optional)</label>
                    <textarea name="specialRequests" rows="3" class="w-full px-4 py-3 rounded-lg border border-stone-300 focus:ring-2 focus:ring-royal-red focus:border-royal-red outline-none transition-shadow bg-stone-50 placeholder-stone-400" placeholder="E.g., Window seat, celebrating an anniversary..."></textarea>
                </div>
                
                <div class="pt-4">
                    <button type="submit" class="w-full bg-royal-red hover:bg-royal-redHover text-white font-bold py-4 rounded-lg shadow-lg transition-all transform hover:-translate-y-1">
                        Confirm Reservation
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>

<%- include('partials/footer') %>