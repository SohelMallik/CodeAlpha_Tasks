<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Title Image (Favicon) -->
    <link rel="icon" type="image/png" href="/images/mainlogoremovebg.png">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 flex h-screen relative z-0">

    <!-- Transparent Background Watermark -->
    <div class="fixed inset-0 z-[-1] flex items-center justify-center pointer-events-none overflow-hidden ml-0 md:ml-64">
        <img src="/images/mainlogoremovebg.png" alt="Watermark" class="w-[80%] md:w-[50%] object-contain opacity-5 grayscale">
    </div>

    <!-- Admin Sidebar -->
    <aside class="w-64 bg-slate-900 text-white flex flex-col hidden md:flex z-10">
        <div class="p-6">
            <h2 class="text-2xl font-bold font-serif text-amber-400">The Royals</h2>
            <p class="text-xs text-slate-400 uppercase tracking-wider mt-1">Management Portal</p>
        </div>
        <nav class="flex-1 px-4 space-y-2 mt-4">
            <a href="/admin" class="block px-4 py-3 bg-slate-800 rounded-lg text-white font-medium">Reservations</a>
            <a href="/admin/menu" class="block px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors">Menu Manager</a>
            <a href="/" target="_blank" class="block px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors mt-8">View Live Site ↗</a>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto p-8 z-10">
        <header class="mb-8 flex justify-between items-center">
            <h1 class="text-3xl font-bold text-gray-800">Table Reservations</h1>
        </header>

        <!-- Reservations Table -->
        <div class="bg-white/90 backdrop-blur-sm rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50/90">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date & Time</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Customer Details</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Guests</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    <% if (reservations.length === 0) { %>
                        <tr>
                            <td colspan="5" class="px-6 py-8 text-center text-gray-500">No reservations found.</td>
                        </tr>
                    <% } else { %>
                        <% reservations.forEach(res => { %>
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="font-medium text-gray-900"><%= res.date %></div>
                                    <div class="text-sm text-gray-500"><%= res.time %></div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="font-medium text-gray-900"><%= res.name %></div>
                                    <div class="text-sm text-gray-500"><%= res.phone %></div>
                                    <% if (res.specialRequests) { %>
                                        <div class="text-xs text-amber-600 mt-1">Note: <%= res.specialRequests %></div>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-gray-500">
                                    <%= res.guests %> People
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full 
                                        <%= res.status === 'Pending' ? 'bg-yellow-100 text-yellow-800' : '' %>
                                        <%= res.status === 'Confirmed' ? 'bg-green-100 text-green-800' : '' %>
                                        <%= res.status === 'Cancelled' ? 'bg-red-100 text-red-800' : '' %>">
                                        <%= res.status %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                    <form action="/admin/reservations/update/<%= res._id %>" method="POST" class="flex gap-2">
                                        <select name="status" class="border rounded px-2 py-1 text-sm bg-gray-50" onchange="this.form.submit()">
                                            <option value="Pending" <%= res.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                                            <option value="Confirmed" <%= res.status === 'Confirmed' ? 'selected' : '' %>>Confirm</option>
                                            <option value="Cancelled" <%= res.status === 'Cancelled' ? 'selected' : '' %>>Cancel</option>
                                        </select>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>