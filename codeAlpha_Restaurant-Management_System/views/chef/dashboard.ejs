<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Title Image (Favicon) -->
    <link rel="icon" type="image/png" href="/images/mainlogoremovebg.png">
    <script src="https://cdn.tailwindcss.com"></script>
    <meta http-equiv="refresh" content="15">
</head>
<body class="bg-gray-900 text-gray-100 font-sans h-screen flex flex-col overflow-hidden relative z-0">

    <!-- Transparent Background Watermark (Darker for Chef Portal) -->
    <div class="fixed inset-0 z-[-1] flex items-center justify-center pointer-events-none overflow-hidden">
        <img src="/images/mainlogoremovebg.png" alt="Watermark" class="w-[80%] md:w-[40%] object-contain opacity-[0.03] grayscale">
    </div>

    <!-- Chef Header -->
    <header class="bg-gray-800/90 backdrop-blur-sm border-b border-gray-700 py-4 px-6 flex justify-between items-center shadow-lg z-10">
        <div class="flex items-center gap-4">
            <h1 class="text-3xl font-bold text-white tracking-wider">KITCHEN DISPLAY</h1>
            <span class="bg-green-500/20 text-green-400 border border-green-500/50 px-3 py-1 rounded-full text-sm font-semibold animate-pulse">
                Live System Active
            </span>
        </div>
        <div class="text-gray-400 font-mono text-xl" id="clock">
            00:00:00
        </div>
    </header>

    <!-- Orders Kanban Board -->
    <main class="flex-1 overflow-x-auto p-6 flex gap-6 align-top z-10">
        
        <% if (activeOrders.length === 0) { %>
            <div class="w-full flex items-center justify-center">
                <h2 class="text-4xl text-gray-600 font-bold">NO ACTIVE ORDERS</h2>
            </div>
        <% } else { %>
            
            <% activeOrders.forEach(order => { %>
                <div class="min-w-[350px] w-[350px] bg-gray-800/95 backdrop-blur-md rounded-xl flex flex-col shadow-2xl border-t-4 <%= order.status === 'Received' ? 'border-red-500' : 'border-yellow-500' %>">
                    
                    <div class="p-4 border-b border-gray-700 bg-gray-800/50 rounded-t-xl">
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="text-xl font-bold text-white">#<%= order._id.toString().slice(-4).toUpperCase() %></h3>
                            <span class="text-sm font-mono text-gray-400"><%= new Date(order.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></span>
                        </div>
                        <div class="flex justify-between text-sm text-gray-400">
                            <span><%= order.customerName %></span>
                            <% if (order.tableNumber) { %>
                                <span class="bg-gray-700 text-white px-2 py-0.5 rounded font-bold">Table <%= order.tableNumber %></span>
                            <% } else { %>
                                <span class="bg-blue-900/50 text-blue-300 px-2 py-0.5 rounded font-bold">Takeaway</span>
                            <% } %>
                        </div>
                    </div>

                    <div class="p-4 flex-1 overflow-y-auto">
                        <ul class="space-y-4">
                            <% order.items.forEach(item => { %>
                                <li class="flex gap-4 text-lg items-center border-b border-gray-700/50 pb-3 last:border-0">
                                    <span class="bg-gray-700 text-white font-bold w-10 h-10 flex items-center justify-center rounded-lg shadow-inner"><%= item.quantity %>x</span>
                                    <span class="font-medium text-gray-200"><%= item.name %></span>
                                </li>
                            <% }) %>
                        </ul>
                        
                        <% if (order.specialInstructions) { %>
                            <div class="mt-4 p-3 bg-red-900/20 border border-red-500/30 rounded-lg">
                                <span class="uppercase text-xs font-bold text-red-400 block mb-1">⚠️ Special Instructions:</span>
                                <p class="text-red-200 text-sm font-medium"><%= order.specialInstructions %></p>
                            </div>
                        <% } %>
                    </div>

                    <div class="p-4 bg-gray-900/90 rounded-b-xl border-t border-gray-700 mt-auto">
                        <form action="/chef/update-status/<%= order._id %>" method="POST">
                            <% if (order.status === 'Received') { %>
                                <input type="hidden" name="status" value="Preparing">
                                <button type="submit" class="w-full bg-yellow-600 hover:bg-yellow-500 text-white font-bold py-4 text-xl rounded-lg shadow-lg transition-colors">
                                    START PREPARING
                                </button>
                            <% } else if (order.status === 'Preparing') { %>
                                <input type="hidden" name="status" value="Ready">
                                <button type="submit" class="w-full bg-green-600 hover:bg-green-500 text-white font-bold py-4 text-xl rounded-lg shadow-lg transition-colors">
                                    MARK READY
                                </button>
                            <% } %>
                        </form>
                    </div>
                </div>
            <% }) %>
            
        <% } %>

    </main>

    <script>
        setInterval(() => {
            document.getElementById('clock').innerText = new Date().toLocaleTimeString();
        }, 1000);
    </script>
</body>
</html>